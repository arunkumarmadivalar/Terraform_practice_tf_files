terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "6.51.0"
    }
  }
}

provider "aws" {
  region = "us-east-1"  
}

resource "aws_instance" "web_server" {
  ami           = "ami-08f44e8eca9095668" # Example Amazon Linux 2 AMI
  instance_type = "t3.micro"

  tags = {
    Name = "web-server"
  }
}
